{
  "version": 2,
  "buildCommand": "npm run build -w frontend",
  "installCommand": "npm install",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api).*)", "destination": "/" }
  ]
}
